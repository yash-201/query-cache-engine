{
  "name": "query-cache-engine",
  "version": "1.0.2",
  "description": "Transparent Redis caching package with request coalescing, stable key generation, and Express middleware",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:express": "ts-node examples/express/server.ts",
    "example:fastify": "ts-node examples/fastify/server.ts"
  },
  "keywords": [
    "redis",
    "caching",
    "cache",
    "express",
    "middleware",
    "coalescing",
    "single-flight",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "dependencies": {
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@types/express": "^4.17.21",
    "@types/koa": "^3.0.3",
    "@types/node": "^20.11.24",
    "express": "^4.19.2",
    "fastify": "^4.26.1",
    "hono": "^4.12.30",
    "koa": "^3.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
